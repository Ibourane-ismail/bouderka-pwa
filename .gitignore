# =========================================================
# BOUDERKA PWA - .gitignore
# React + Vite + Node.js + Express + Prisma + MySQL
# =========================================================

# =========================================================
# Dépendances
# =========================================================
node_modules/
.pnp
.pnp.js

# =========================================================
# Build & Compilation
# =========================================================
dist/
build/
out/
.next/
*.tsbuildinfo

# Build spécifique Vite
client/dist/
server/dist/

# =========================================================
# Variables d'environnement (NE JAMAIS VERSIONNER)
# =========================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# =========================================================
# Logs
# =========================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================================================
# Cache
# =========================================================
.cache/
.npm/
.yarn/
.parcel-cache/
.vite/
.eslintcache

# =========================================================
# Couverture des tests
# =========================================================
coverage/
.nyc_output/
*.lcov

# =========================================================
# Prisma
# =========================================================
# Base SQLite (si utilisée pour les tests)
prisma/*.db
prisma/*.db-journal

# IMPORTANT :
# Conserver les fichiers suivants :
# prisma/schema.prisma
# prisma/migrations/

# =========================================================
# Fichiers temporaires
# =========================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.rej
*~

# =========================================================
# Système d'exploitation
# =========================================================
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# =========================================================
# VS Code
# =========================================================
.vscode/*
!.vscode/extensions.json

# =========================================================
# JetBrains
# =========================================================
.idea/

# =========================================================
# Vim
# =========================================================
*.swp
*.swo

# =========================================================
# Certificats & Clés
# =========================================================
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# Clés Firebase
firebase-service-account.json

# =========================================================
# Archives
# =========================================================
*.zip
*.tar
*.gz
*.rar
*.7z

# =========================================================
# Divers
# =========================================================
*.pid
*.seed

# =========================================================
# IMPORTANT
# Les fichiers suivants DOIVENT être versionnés :
#
# ✔ package.json
# ✔ package-lock.json
# ✔ vite.config.js
# ✔ server.js
# ✔ client/
# ✔ server/
# ✔ src/
# ✔ public/
# ✔ prisma/schema.prisma
# ✔ prisma/migrations/
# ✔ README.md
# ✔ .env.example
# =========================================================